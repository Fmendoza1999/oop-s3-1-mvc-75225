@model IEnumerable<VgcCollege.Web.Models.StudentProfile>
@{
    ViewData["Title"] = "Students";
}

<h2>All Students</h2>
<a asp-action="Index" class="btn btn-secondary mb-3">← Back to Dashboard</a>
<a asp-action="CreateStudent" class="btn btn-primary mb-3 ms-2">+ Add Student</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Student Number</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model)
        {
            <tr>
                <td>@student.StudentNumber</td>
                <td>@student.Name</td>
                <td>@student.Email</td>
                <td>@student.Phone</td>
                <td>
                    <a asp-action="EditStudent" asp-route-id="@student.Id"
                       class="btn btn-sm btn-outline-primary">Edit</a>
                </td>
            </tr>
        }
    </tbody>
</table>