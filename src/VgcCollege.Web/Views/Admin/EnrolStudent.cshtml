@{
    ViewData["Title"] = "Enrol Student";
}

<h2>Enrol Student in Course</h2>
<a asp-action="Enrolments" class="btn btn-secondary mb-3">← Back to Enrolments</a>

<div style="max-width:500px">
    <form asp-action="EnrolStudent" asp-controller="Admin" method="post">
        <div class="mb-3">
            <label class="form-label">Student</label>
            <select name="studentProfileId" class="form-select" required>
                <option value="">-- Select Student --</option>
                @foreach (var student in ViewBag.Students)
                {
                    <option value="@student.Id">@student.Name (@student.StudentNumber)</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Course</label>
            <select name="courseId" class="form-select" required>
                <option value="">-- Select Course --</option>
                @foreach (var course in ViewBag.Courses)
                {
                    <option value="@course.Id">@course.Name</option>
                }
            </select>
        </div>
        <div class="mb-3">
            <label class="form-label">Assign Faculty (optional)</label>
            <select name="facultyProfileId" class="form-select">
                <option value="">-- No Faculty --</option>
                @foreach (var faculty in ViewBag.Faculty)
                {
                    <option value="@faculty.Id">@faculty.Name</option>
                }
            </select>
        </div>
        <button type="submit" class="btn btn-primary">Enrol Student</button>
    </form>
</div>