@model IEnumerable<VgcCollege.Web.Models.ExamResult>
@{
    ViewData["Title"] = "My Exam Results";
}

<h2>My Exam Results</h2>
<a asp-action="Index" class="btn btn-secondary mb-3">← Back to Dashboard</a>

@if (!Model.Any())
{
    <div class="alert alert-info">No released exam results yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Exam</th>
                <th>Date</th>
                <th>Score</th>
                <th>Grade</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Model)
            {
                <tr>
                    <td>@result.Exam.Title</td>
                    <td>@result.Exam.Date.ToShortDateString()</td>
                    <td>@result.Score / @result.Exam.MaxScore</td>
                    <td>@result.Grade</td>
                </tr>
            }
        </tbody>
    </table>
}