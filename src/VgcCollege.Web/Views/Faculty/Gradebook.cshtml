@model IEnumerable<VgcCollege.Web.Models.AssignmentResult>
@{
    ViewData["Title"] = "Gradebook";
}

<h2>Gradebook</h2>
<a asp-action="Index" class="btn btn-secondary mb-3">← Back to Dashboard</a>
<a asp-action="AddResult" class="btn btn-primary mb-3 ms-2">+ Add Assignment Result</a>
<a asp-action="AddExamResult" class="btn btn-success mb-3 ms-2">+ Add Exam Result</a>

@if (!Model.Any())
{
    <div class="alert alert-info">No assignment results yet.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Student</th>
                <th>Assignment</th>
                <th>Score</th>
                <th>Max Score</th>
                <th>Feedback</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var result in Model)
            {
                <tr>
                    <td>@result.Student.Name</td>
                    <td>@result.Assignment.Title</td>
                    <td>@result.Score</td>
                    <td>@result.Assignment.MaxScore</td>
                    <td>@result.Feedback</td>
                </tr>
            }
        </tbody>
    </table>
}